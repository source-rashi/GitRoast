# GitRoast Environment Variables
# Copy this file to .env and fill in your values
# ALL of these are 100% FREE — no credit card required anywhere

# =============================================================================
# REQUIRED
# =============================================================================

# --- Groq API (Primary LLM) ---
# Get for free at: https://console.groq.com → "Create API Key"
# Takes ~30 seconds. No credit card. No limits on free tier.
GROQ_API_KEY=gsk_your_groq_key_here

# --- GitHub Personal Access Token ---
# Get at: https://github.com/settings/tokens → "Generate new token (classic)"
# Scopes needed: read:user, public_repo
# Without this: 60 requests/hour. With this: 5,000 requests/hour.
# Also needed for: Competitor Researcher (GitHub Search API)
#                  Project Scaffolder repo creation (needs "repo" scope too)
GITHUB_TOKEN=ghp_your_github_token_here

# =============================================================================
# OPTIONAL — sensible defaults are set if not provided
# =============================================================================

# --- Groq model override ---
# Default: llama3-70b-8192 (free, fast, excellent for roasting)
# Alternatives: llama3-8b-8192 (faster), mixtral-8x7b-32768 (longer context)
GROQ_MODEL=llama3-70b-8192

# --- Debug logging ---
# Set to "false" in production to reduce log noise
DEBUG=true

# =============================================================================
# LEGACY / UNUSED (kept for backward compat — not required)
# =============================================================================

# These were planned for future phases but not currently used
GEMINI_API_KEY=
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8765
