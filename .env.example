# GitRoast Environment Variables
# Copy this file to .env and fill in your values
# ALL of these are 100% FREE — no credit card required

# === GROQ API (Primary LLM — Free at console.groq.com) ===
GROQ_API_KEY=<paste-your-groq-key-here>
GROQ_MODEL=llama3-70b-8192

# === GITHUB (Free — generate at github.com/settings/tokens) ===
# Scopes needed: read:user, public_repo
GITHUB_TOKEN=<paste-your-github-pat-here>

# === GOOGLE GEMINI (Backup LLM — Free at aistudio.google.com) ===
GEMINI_API_KEY=<paste-your-gemini-key-here>

# === APP CONFIG ===
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8765
DEBUG=true
